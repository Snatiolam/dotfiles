# ==========================================
# Ghostty Configuration
# ==========================================

theme = TokyoNight Storm

font-family = MonaspiceNe Nerd Font
font-family = monospace
font-size = 14

window-padding-x = 12
window-padding-y = 12

window-decoration = true
gtk-titlebar = false

# --- Keybindings ---
keybind = ctrl+shift+d=toggle_window_decorations
